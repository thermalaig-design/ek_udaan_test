{
  "appId": "com.ekudaan.app",
  "appName": "Pankhuri Ek Udaan",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#111827",
      "overlaysWebView": false
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "showSpinner": false,
      "fadeOutDuration": 500
    },
    "LocalNotifications": {
      "iconColor": "#4F46E5"
    }
  },
  "android": {
    "backgroundColor": "#111827"
  }
}
